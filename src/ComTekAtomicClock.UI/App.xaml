<Application x:Class="ComTekAtomicClock.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:ComTekAtomicClock.UI"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                  WPF-UI Fluent theme. Theme="Dark" matches the
                  navy/amber Atomic Lab palette and our existing
                  dark window backgrounds. ControlsDictionary
                  applies Fluent styling to standard WPF controls
                  (Menu, TabControl, Button, ComboBox, StatusBar,
                  etc.) automatically.
                -->
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
