<ui:FluentWindow x:Class="ComTekAtomicClock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:ComTekAtomicClock.UI"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        mc:Ignorable="d"
        Title="ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="560"
        MinHeight="420" MinWidth="380"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <DockPanel>

        <!-- ============================== Title Bar ============================= -->
        <!--
          Wpf.Ui's TitleBar replaces the standard Windows title bar
          when ExtendsContentIntoTitleBar=True. Drag-to-move,
          minimize/maximize/close, and the icon are all handled.
        -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ComTek Atomic Clock">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ============================== §1.9 Banner =========================== -->
        <Border DockPanel.Dock="Top"
                Background="#7a3a1a"
                BorderBrush="#a85a2a"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="{Binding BannerButtonText}"
                           Command="{Binding InstallServiceCommand}"
                           Appearance="Primary"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding BannerHeadlineText}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#fff5d8"/>
                    <TextBlock Text="The clock keeps displaying time, but it isn't being synced to NIST until the service is running."
                               FontSize="11"
                               Foreground="#f0e0c0"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================== Status Bar ============================ -->
        <StatusBar DockPanel.Dock="Bottom"
                   FontSize="11"
                   Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding ServiceStatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <!--
                  Live last-sync display. Bound to MainWindowViewModel
                  .LastSyncText, which is re-rendered every second so the
                  relative-time component stays current. Source data is
                  fetched over the named-pipe IPC every 5 s while the
                  service is running. Format examples:
                    "Last sync: 12s ago (corrected −8.7 ms)"
                    "Last sync: 47m ago (corrected +2.3 s)"
                    "Last sync: pending…"
                    "Last sync: service not running"
                    "Last sync failed: <reason>"
                -->
                <TextBlock Text="{Binding LastSyncText}"
                           Opacity="0.6"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================== Tab Toolbar =========================== -->
        <!--
          Compact toolbar above the tab strip with the "+ New tab" and
          "+ New window" buttons. Replaces Dragablz's intrinsic "+"
          add-button (which only created tabs in-place — there was no
          equivalent affordance for "open a new free-floating clock
          window"). Per v0.0.33 the user explicitly chooses tabbed vs.
          windowed at creation time; tear-away is gone, so this
          toolbar is the only path to a new floating clock.
        -->
        <Border DockPanel.Dock="Top"
                Background="#F5F5F5"
                BorderBrush="#C0C0C0"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <StackPanel Orientation="Horizontal">
                <Button Content="+ New tab"
                        Command="{Binding AddTabCommand}"
                        Padding="8,2"
                        Margin="0,0,4,0"
                        ToolTip="Add a new tab to this window"/>
                <Button Content="+ New window"
                        Command="{Binding NewClockWindowCommand}"
                        Padding="8,2"
                        ToolTip="Open a new free-floating clock window"/>
            </StackPanel>
        </Border>

        <!-- ============================== Tab Strip ============================= -->
        <!--
          Native WPF System.Windows.Controls.TabControl, replacing
          Dragablz's TabablzControl in v0.0.33. The native control
          honors PropertyChanged on ItemTemplate bindings reliably,
          so {Binding Label} re-renders the tab header on TZ change
          without any imperative refresh code. Tear-away is gone;
          tabs↔windows transitions go through explicit commands.

          Per-tab interactions:
            · Single-click → select (native, reliable, no Preview hook needed)
            · Double-click → open Tab Settings dialog (handler in code-behind)
            · Right-click  → ContextMenu with "Tab settings…" + "Open in new window"
            · ✕ overlay on the clock face → close this tab
            · "+ New tab" button in toolbar above → AddTabCommand
            · "+ New window" button in toolbar above → NewClockWindowCommand
        -->
        <TabControl x:Name="MainTabs"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="White"
                    BorderBrush="#C0C0C0"
                    Padding="0">

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <!--
                      Native TabControl honors {Binding Label}
                      PropertyChanged automatically; no Tag attribute or
                      imperative refresh walker needed (the v0.0.14..0.0.32
                      Dragablz workaround lineage is gone).
                    -->
                    <TextBlock Text="{Binding Label}"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <!--
                      Full ControlTemplate replacement gives us a flat
                      rectangular tab matching the v0.0.32 visual without
                      the native TabItem's curved-corner Aero look.
                      The Border carries the per-state brushes; the
                      ContentPresenter renders the ItemTemplate.
                    -->
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="0,0,0,0">
                                    <ContentPresenter x:Name="TabContent"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      TextBlock.FontSize="{TemplateBinding FontSize}"
                                                      TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <!-- Lift the active tab z-order so its border overlaps neighbors. -->
                                        <Setter TargetName="TabBorder" Property="Panel.ZIndex" Value="1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Background"  Value="#E8E8E8"/>
                    <Setter Property="Foreground"  Value="Black"/>
                    <Setter Property="BorderBrush" Value="#C0C0C0"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                    <Setter Property="Padding" Value="10,4"/>
                    <!--
                      Inactive-tab base FontSize=9; active-tab FontSize=19
                      via the IsSelected=True trigger below. Delta is +10 pt,
                      reflecting Dan's v0.0.28..v0.0.30 size pass — the
                      large active tab + Bold weight makes selection
                      unambiguous on a full strip.
                    -->
                    <Setter Property="FontSize" Value="9"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <EventSetter Event="MouseDoubleClick"
                                 Handler="TabItem_DoubleClick"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Tab settings…"
                                          Click="TabContextSettings_Click"/>
                                <Separator/>
                                <MenuItem Header="Open in new window"
                                          Click="TabContextOpenInNewWindow_Click"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"  Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="#808080"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize"   Value="19"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.ItemContainerStyle>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <!--
                      Layout: outer Viewbox uniformly scales a fixed
                      400×400 logical canvas to fit the available tab
                      content area. The 400×400 frame matches the
                      design SVGs and ClockFaceControl's own internal
                      400×400 Canvas.
                    -->
                    <Viewbox Stretch="Uniform" Margin="20">
                        <Grid Width="400" Height="400">
                            <controls:ClockFaceControl
                                Width="400" Height="400"
                                TimeZone="{Binding TimeZone}"
                                Theme="{Binding Theme}"
                                SmoothSecondHand="{Binding SmoothSecondHand}"/>

                            <!--
                              ✕ close tab and ? help/about overlay
                              buttons. Foreground bound to
                              TabViewModel.OverlayGlyphBrush so dark
                              themes get white glyphs and light themes
                              get near-black. Position is in the 400×400
                              logical canvas; the Viewbox scales it.
                            -->
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,14,16,0"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Close this tab"
                                    Command="{Binding DataContext.CloseTabCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="&#x2715;"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="{Binding OverlayGlyphBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,42,16,0"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Help / About"
                                    Click="HelpButton_Click">
                                <TextBlock Text="?"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="{Binding OverlayGlyphBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Themes…"
                                                  Click="ThemesMenuItem_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Help…"
                                                  Click="HelpMenuItem_Click"/>
                                        <MenuItem Header="About…"
                                                  Click="AboutMenuItem_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </Viewbox>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</ui:FluentWindow>
