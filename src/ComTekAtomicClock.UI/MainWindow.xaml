<ui:FluentWindow x:Class="ComTekAtomicClock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dragablz="http://dragablz.net/winfx/xaml/dragablz"
        xmlns:local="clr-namespace:ComTekAtomicClock.UI"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        mc:Ignorable="d"
        Title="ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="560"
        MinHeight="420" MinWidth="380"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <DockPanel>

        <!-- ============================== Title Bar ============================= -->
        <!--
          Wpf.Ui's TitleBar replaces the standard Windows title bar
          when ExtendsContentIntoTitleBar=True. Drag-to-move,
          minimize/maximize/close, and the icon are all handled.
        -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ComTek Atomic Clock">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- ============================== Menu Bar ============================== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="ExitMenu_Click"/>
            </MenuItem>

            <MenuItem Header="_Tabs">
                <MenuItem Header="Tab _settings…"
                          Command="{Binding OpenTabSettingsCommand}"
                          InputGestureText="Ctrl+,"/>
                <Separator/>
                <MenuItem Header="_Add new tab"
                          Command="{Binding AddTabCommand}"/>
                <MenuItem Header="_Remove this tab"
                          Command="{Binding RemoveTabCommand}"/>
            </MenuItem>

            <MenuItem Header="_Service">
                <MenuItem Header="_Install / start the time-sync service"
                          Command="{Binding InstallServiceCommand}"/>
                <MenuItem Header="_Uninstall the time-sync service…"
                          Command="{Binding UninstallServiceCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About ComTek Atomic Clock…"
                          Command="{Binding OpenAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ============================== §1.9 Banner =========================== -->
        <Border DockPanel.Dock="Top"
                Background="#7a3a1a"
                BorderBrush="#a85a2a"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="{Binding BannerButtonText}"
                           Command="{Binding InstallServiceCommand}"
                           Appearance="Primary"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding BannerHeadlineText}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#fff5d8"/>
                    <TextBlock Text="The clock keeps displaying time, but it isn't being synced to NIST until the service is running."
                               FontSize="11"
                               Foreground="#f0e0c0"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================== Status Bar ============================ -->
        <StatusBar DockPanel.Dock="Bottom"
                   FontSize="11"
                   Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding ServiceStatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Last sync: (not yet wired — Step 6d)"
                           Opacity="0.6"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================== Tab Strip ============================= -->
        <!--
          Dragablz TabablzControl gives the Chrome / Edge-style tab UX:
            · per-tab close button (✕)
            · "+" button to add a new tab
            · drag-to-reorder within the strip
          Tear-off (drag a tab into its own window) requires an
          IInterTabClient implementation and a multi-window settings
          model — coming in the next commit.
        -->
        <dragablz:TabablzControl x:Name="MainTabs"
                                 ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 ShowDefaultCloseButton="True"
                                 ShowDefaultAddButton="True"
                                 NewItemFactory="{Binding NewTabFactory}"
                                 ConsolidateOrphanedItems="True"
                                 DisplayMemberPath="Label"
                                 Padding="0">
            <dragablz:TabablzControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <controls:ClockFaceControl
                            Margin="20"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            TimeZone="{Binding TimeZone}"
                            Theme="{Binding Theme}"
                            SmoothSecondHand="{Binding SmoothSecondHand}"/>
                    </Grid>
                </DataTemplate>
            </dragablz:TabablzControl.ContentTemplate>
        </dragablz:TabablzControl>

    </DockPanel>
</ui:FluentWindow>
