<Window x:Class="ComTekAtomicClock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ComTekAtomicClock.UI"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        mc:Ignorable="d"
        Title="ComTek Atomic Clock"
        Height="640" Width="560"
        MinHeight="420" MinWidth="380"
        Background="#060D1A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- ============================== Menu Bar ============================== -->
        <!--
          Letting the Menu use the system default colors fixes the
          low-contrast issue Dan flagged ("almost a whiteout"). The
          menu sits as a thin light-gray strip with black text against
          the dark navy window background — clean and readable.
        -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="ExitMenu_Click"/>
            </MenuItem>

            <MenuItem Header="_Tabs">
                <MenuItem Header="Tab _settings…"
                          Command="{Binding OpenTabSettingsCommand}"
                          InputGestureText="Ctrl+,"/>
                <Separator/>
                <MenuItem Header="_Add new tab"
                          Command="{Binding AddTabCommand}"/>
                <MenuItem Header="_Remove this tab"
                          Command="{Binding RemoveTabCommand}"/>
            </MenuItem>

            <MenuItem Header="_Service">
                <MenuItem Header="_Install / start the time-sync service"
                          Command="{Binding InstallServiceCommand}"/>
                <MenuItem Header="_Uninstall the time-sync service…"
                          Command="{Binding UninstallServiceCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About ComTek Atomic Clock…"
                          Command="{Binding OpenAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ============================== §1.9 Banner =========================== -->
        <Border DockPanel.Dock="Top"
                Background="#7a3a1a"
                BorderBrush="#a85a2a"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding BannerButtonText}"
                        Command="{Binding InstallServiceCommand}"
                        Padding="14,6"
                        FontWeight="SemiBold"
                        Margin="12,0,0,0"
                        Background="#FFB000"
                        Foreground="#0a0a0a"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding BannerHeadlineText}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#fff5d8"/>
                    <TextBlock Text="The clock keeps displaying time, but it isn't being synced to NIST until the service is running."
                               FontSize="11"
                               Foreground="#f0e0c0"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================== Status Bar ============================ -->
        <!--
          Status bar at the bottom of the window. ServiceStatusText is
          a one-line summary; live last-sync info (offset, age, source
          server) lands in the next commit when IPC integration goes
          in.
        -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#0a1628"
                   Foreground="#A8A39A"
                   FontSize="11"
                   Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding ServiceStatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Last sync: (not yet wired — Step 6d)"
                           Foreground="#666"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================== Tab Strip ============================= -->
        <TabControl x:Name="MainTabs"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}"
                    Background="#060D1A"
                    BorderBrush="#1A2A4A"
                    BorderThickness="0,1,0,0"
                    Padding="0">
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <!--
                      Tab header is just the label now. The gear-button
                      pop-over from Step 6 is gone; per-tab settings
                      live in Tabs -> Tab settings… (Ctrl+,) and edit
                      the SELECTED tab via the modal dialog.
                    -->
                    <TextBlock Text="{Binding Label}"
                               VerticalAlignment="Center"
                               FontSize="13"/>
                </DataTemplate>
            </TabControl.ItemTemplate>

            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Grid Background="#060D1A">
                        <controls:ClockFaceControl
                            Margin="20"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            TimeZone="{Binding TimeZone}"
                            Theme="{Binding Theme}"
                            SmoothSecondHand="{Binding SmoothSecondHand}"/>
                    </Grid>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>

    </DockPanel>
</Window>
