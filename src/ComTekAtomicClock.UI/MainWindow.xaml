<ui:FluentWindow x:Class="ComTekAtomicClock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dragablz="http://dragablz.net/winfx/xaml/dragablz"
        xmlns:local="clr-namespace:ComTekAtomicClock.UI"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        xmlns:services="clr-namespace:ComTekAtomicClock.UI.Services"
        mc:Ignorable="d"
        Title="ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="560"
        MinHeight="420" MinWidth="380"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <services:AppInterTabClient x:Key="MainInterTabClient"/>
    </ui:FluentWindow.Resources>

    <DockPanel>

        <!-- ============================== Title Bar ============================= -->
        <!--
          Wpf.Ui's TitleBar replaces the standard Windows title bar
          when ExtendsContentIntoTitleBar=True. Drag-to-move,
          minimize/maximize/close, and the icon are all handled.
        -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ComTek Atomic Clock">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--
          Menu bar removed per Dan's UX call: the only thing above the
          banner is now the Wpf.Ui title bar (drag / minimize / maximize
          / close). Tab settings reachable via Ctrl+,. Add Tab via the
          Dragablz "+" button. Remove Tab via each tab's "x" button.
          Help/About reachable via the "?" overlay in the bottom-left
          of the tab content. Uninstall the service via a link on the
          About dialog.
        -->

        <!-- ============================== §1.9 Banner =========================== -->
        <Border DockPanel.Dock="Top"
                Background="#7a3a1a"
                BorderBrush="#a85a2a"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="{Binding BannerButtonText}"
                           Command="{Binding InstallServiceCommand}"
                           Appearance="Primary"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding BannerHeadlineText}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#fff5d8"/>
                    <TextBlock Text="The clock keeps displaying time, but it isn't being synced to NIST until the service is running."
                               FontSize="11"
                               Foreground="#f0e0c0"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================== Status Bar ============================ -->
        <StatusBar DockPanel.Dock="Bottom"
                   FontSize="11"
                   Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding ServiceStatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Last sync: (not yet wired — Step 6d)"
                           Opacity="0.6"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================== Tab Strip ============================= -->
        <!--
          Dragablz TabablzControl gives the Chrome / Edge-style tab UX:
            · per-tab close button (✕)
            · "+" button to add a new tab
            · drag-to-reorder within the strip
          Tear-off (drag a tab into its own window) requires an
          IInterTabClient implementation and a multi-window settings
          model — coming in the next commit.
        -->
        <dragablz:TabablzControl x:Name="MainTabs"
                                 ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 ShowDefaultCloseButton="True"
                                 ShowDefaultAddButton="True"
                                 NewItemFactory="{Binding NewTabFactory}"
                                 ConsolidateOrphanedItems="True"
                                 Padding="0">
            <dragablz:TabablzControl.InterTabController>
                <dragablz:InterTabController InterTabClient="{StaticResource MainInterTabClient}"/>
            </dragablz:TabablzControl.InterTabController>
            <!--
              Tab header rendering: TabViewModel.ToString() returns
              the Label, which Dragablz uses as the tab header text.
              (Wpf.Ui's restyled TabItem template fights with our
              ItemTemplate, so we lean on the ToString fallback rather
              than chasing the styling battle.)

              For changing the timezone / theme of a tab, the user has
              two affordances:
                · Double-click the tab → opens TabSettings for it.
                · Right-click the tab → context menu with "Tab
                  settings…" and "Close tab" entries.
            -->
            <dragablz:TabablzControl.ItemContainerStyle>
                <Style TargetType="dragablz:DragablzItem">
                    <EventSetter Event="MouseDoubleClick"
                                 Handler="TabItem_DoubleClick"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Tab settings…"
                                          Click="TabContextSettings_Click"/>
                                <Separator/>
                                <MenuItem Header="Close tab"
                                          Click="TabContextClose_Click"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>
            </dragablz:TabablzControl.ItemContainerStyle>

            <dragablz:TabablzControl.ContentTemplate>
                <DataTemplate>
                    <Grid>
                        <controls:ClockFaceControl
                            Margin="20"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            TimeZone="{Binding TimeZone}"
                            Theme="{Binding Theme}"
                            SmoothSecondHand="{Binding SmoothSecondHand}"/>

                        <!--
                          Discreet help (?) button anchored to the
                          bottom-left of the tab content. Click opens
                          the About dialog. Uses RelativeSource to
                          reach the MainWindow's MainWindowViewModel
                          since each tab's DataContext is its own
                          TabViewModel.
                        -->
                        <ui:Button HorizontalAlignment="Left"
                                   VerticalAlignment="Bottom"
                                   Margin="10,0,0,10"
                                   Width="32" Height="32"
                                   Padding="0"
                                   Appearance="Secondary"
                                   ToolTip="About ComTek Atomic Clock"
                                   Command="{Binding DataContext.OpenAboutCommand,
                                             RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock Text="?"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </ui:Button>

                        <!--
                          ✕ overlay in the upper-right of the tab
                          content. Just the glyph — no Wpf.Ui Button
                          chrome — so it sits flush over the clock
                          face. Black foreground reads on the
                          light-themed faces (Boulder Slate, Aero
                          Glass, Daylight); on the dark themes the
                          MouseOver state lifts opacity.
                          Margin pushed inward so it sits clearly
                          inside the clock area, not on the rim.
                        -->
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,28,28,0"
                                Width="22" Height="22"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                ToolTip="Close this tab"
                                Command="{Binding DataContext.CloseTabCommand,
                                          RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}">
                            <TextBlock Text="&#x2715;"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       Foreground="#000"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </dragablz:TabablzControl.ContentTemplate>
        </dragablz:TabablzControl>

    </DockPanel>
</ui:FluentWindow>
