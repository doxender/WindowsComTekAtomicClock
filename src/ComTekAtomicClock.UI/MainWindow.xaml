<ui:FluentWindow x:Class="ComTekAtomicClock.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:dragablz="http://dragablz.net/winfx/xaml/dragablz"
        xmlns:local="clr-namespace:ComTekAtomicClock.UI"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        xmlns:services="clr-namespace:ComTekAtomicClock.UI.Services"
        mc:Ignorable="d"
        Title="ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="560"
        MinHeight="420" MinWidth="380"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterScreen">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <services:AppInterTabClient x:Key="MainInterTabClient"/>
    </ui:FluentWindow.Resources>

    <DockPanel>

        <!-- ============================== Title Bar ============================= -->
        <!--
          Wpf.Ui's TitleBar replaces the standard Windows title bar
          when ExtendsContentIntoTitleBar=True. Drag-to-move,
          minimize/maximize/close, and the icon are all handled.
        -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ComTek Atomic Clock">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--
          Menu bar removed per Dan's UX call: the only thing above the
          banner is now the Wpf.Ui title bar (drag / minimize / maximize
          / close). Tab settings reachable via Ctrl+,. Add Tab via the
          Dragablz "+" button. Remove Tab via each tab's "x" button.
          Help/About reachable via the "?" overlay in the bottom-left
          of the tab content. Uninstall the service via a link on the
          About dialog.
        -->

        <!-- ============================== §1.9 Banner =========================== -->
        <Border DockPanel.Dock="Top"
                Background="#7a3a1a"
                BorderBrush="#a85a2a"
                BorderThickness="0,0,0,1"
                Padding="16,10"
                Visibility="{Binding BannerVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <ui:Button DockPanel.Dock="Right"
                           Content="{Binding BannerButtonText}"
                           Command="{Binding InstallServiceCommand}"
                           Appearance="Primary"
                           Margin="12,0,0,0"/>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="{Binding BannerHeadlineText}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="#fff5d8"/>
                    <TextBlock Text="The clock keeps displaying time, but it isn't being synced to NIST until the service is running."
                               FontSize="11"
                               Foreground="#f0e0c0"
                               TextWrapping="Wrap"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ============================== Status Bar ============================ -->
        <StatusBar DockPanel.Dock="Bottom"
                   FontSize="11"
                   Padding="8,2">
            <StatusBarItem>
                <TextBlock Text="{Binding ServiceStatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="Last sync: (not yet wired — Step 6d)"
                           Opacity="0.6"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ============================== Tab Strip ============================= -->
        <!--
          Dragablz TabablzControl gives the Chrome / Edge-style tab UX:
            · per-tab close button (✕)
            · "+" button to add a new tab
            · drag-to-reorder within the strip
          Tear-off (drag a tab into its own window) requires an
          IInterTabClient implementation and a multi-window settings
          model — coming in the next commit.
        -->
        <dragablz:TabablzControl x:Name="MainTabs"
                                 ItemsSource="{Binding Tabs}"
                                 SelectedItem="{Binding SelectedTab}"
                                 ShowDefaultCloseButton="True"
                                 ShowDefaultAddButton="True"
                                 NewItemFactory="{Binding NewTabFactory}"
                                 ConsolidateOrphanedItems="True"
                                 Background="White"
                                 BorderBrush="#C0C0C0"
                                 Padding="0">
            <dragablz:TabablzControl.InterTabController>
                <dragablz:InterTabController InterTabClient="{StaticResource MainInterTabClient}"/>
            </dragablz:TabablzControl.InterTabController>
            <!--
              Tab header rendering: explicit ItemTemplate with a
              reactive {Binding Label} binding. Earlier we used
              DisplayMemberPath="Label" + a ToString() override on
              TabViewModel, but in this Dragablz version
              DisplayMemberPath captures the value once at item-add
              time and doesn't refresh on PropertyChanged — so when
              the user changed a tab's timezone via the settings
              dialog, the underlying model updated but the tab header
              kept showing the old label. Tearing the tab off forced
              the new floating window to re-add the item, which
              re-evaluated ToString() and showed the correct label,
              which is the "tear-away fixes it" symptom Dan reported.
              An explicit ItemTemplate with {Binding Label}
              subscribes to PropertyChanged and refreshes live.

              For changing the timezone / theme of a tab, the user has
              two affordances:
                · Double-click the tab → opens TabSettings for it.
                · Right-click the tab → context menu with "Tab
                  settings…" and "Close tab" entries.
            -->
            <dragablz:TabablzControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Label}"
                               VerticalAlignment="Center"/>
                </DataTemplate>
            </dragablz:TabablzControl.ItemTemplate>
            <dragablz:TabablzControl.ItemContainerStyle>
                <Style TargetType="dragablz:DragablzItem">
                    <!--
                      Style overrides ON TOP of Dragablz's default
                      ControlTemplate. We tried fully replacing the
                      template last commit and broke click-to-select
                      and tear-away because Dragablz's selection
                      logic depends on the original template's
                      mouse-event routing through the Thumb. Going
                      back to letting Dragablz own the template and
                      only tuning brushes + a few attached properties
                      from out here.

                      For the yellow accent blocks: the Style.Resources
                      block strips Thumb + FocusVisual + accent
                      candidates that Wpf.Ui's accent brush could be
                      painting. If yellow persists after this, it's
                      coming from an element outside DragablzItem's
                      template (a TabPanel decoration, an inherited
                      style on a sibling) and the next move is to
                      run with VS Live Visual Tree open and identify
                      the offending element by name.
                    -->
                    <!--
                      Yellow-block / dark-active-box fix:
                      Setting Width=0 / Background=Transparent on the
                      Thumb (very early attempt) didn't kill the paint —
                      the Dragablz default Thumb TEMPLATE was rendering
                      with its own brushes (yellow inactive, dark gray
                      selected). v0.0.2 added OverridesDefaultStyle=True
                      + Template-override-with-empty-Border, which
                      killed the paint but left the Thumb naturally
                      sized (it stretched to fill its grid cell in the
                      DragablzItem template), intercepting clicks
                      across the entire tab and making selection take
                      multiple click attempts (Dan's v0.0.3 testing).

                      v0.0.4: keep the empty template (kills paint)
                      AND force Width=0 / MinWidth=0 (zero hit-test
                      area, so the Thumb no longer steals clicks
                      meant for selection). Drag-to-tear still works
                      because Dragablz's tear-away hooks the
                      DragablzItem's MouseMove gesture, not the
                      Thumb's drag events directly.
                    -->
                    <Style.Resources>
                        <Style TargetType="Thumb">
                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                            <Setter Property="Background"  Value="Transparent"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                            <Setter Property="Width"       Value="0"/>
                            <Setter Property="MinWidth"    Value="0"/>
                            <Setter Property="Margin"      Value="0"/>
                            <Setter Property="Padding"     Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Thumb">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Style.Resources>
                    <Setter Property="Background"  Value="White"/>
                    <Setter Property="Foreground"  Value="Black"/>
                    <Setter Property="BorderBrush" Value="#C0C0C0"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                    <Setter Property="Padding" Value="10,4"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <EventSetter Event="MouseDoubleClick"
                                 Handler="TabItem_DoubleClick"/>
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu>
                                <MenuItem Header="Tab settings…"
                                          Click="TabContextSettings_Click"/>
                                <Separator/>
                                <MenuItem Header="Close tab"
                                          Click="TabContextClose_Click"/>
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background"  Value="#FFFFFF"/>
                            <Setter Property="BorderBrush" Value="#808080"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="False">
                            <Setter Property="Background"  Value="#E8E8E8"/>
                            <Setter Property="BorderBrush" Value="#C0C0C0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F5F5F5"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </dragablz:TabablzControl.ItemContainerStyle>

            <dragablz:TabablzControl.ContentTemplate>
                <DataTemplate>
                    <!--
                      Layout: outer Viewbox uniformly scales a fixed
                      400x400 logical canvas to fit the available tab
                      content area. The 400x400 frame matches the
                      design SVGs and ClockFaceControl's own internal
                      400x400 Canvas. Both the clock face AND the
                      overlay buttons live inside this frame, so:
                        · Buttons stay anchored to the dial's
                          upper-right corner regardless of window
                          size — earlier they sat in the wider tab-
                          content Grid and floated way out to the
                          window edge on landscape windows.
                        · Buttons scale with the clock face — bigger
                          window, proportionally bigger buttons.
                      Margin="20" on the Viewbox is the breathing
                      room between the dial and the surrounding
                      panel chrome.
                    -->
                    <Viewbox Stretch="Uniform" Margin="20">
                        <Grid Width="400" Height="400">
                            <controls:ClockFaceControl
                                Width="400" Height="400"
                                TimeZone="{Binding TimeZone}"
                                Theme="{Binding Theme}"
                                SmoothSecondHand="{Binding SmoothSecondHand}"/>

                            <!--
                              ✕ close tab and ? help/about overlay
                              buttons. Foreground bound to
                              TabViewModel.OverlayGlyphBrush so dark
                              themes (Cathode, Atomic Lab, Aero Glass,
                              etc.) get white glyphs and light themes
                              (Boulder Slate, Daylight) get
                              near-black. Position is in the 400x400
                              logical canvas — the Viewbox scales it.
                            -->
                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,14,16,0"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Close this tab"
                                    Command="{Binding DataContext.CloseTabCommand,
                                              RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="&#x2715;"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           Foreground="{Binding OverlayGlyphBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>

                            <Button HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,42,16,0"
                                    Width="22" Height="22"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    ToolTip="Help / About"
                                    Click="HelpButton_Click">
                                <TextBlock Text="?"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Foreground="{Binding OverlayGlyphBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Themes…"
                                                  Click="ThemesMenuItem_Click"/>
                                        <Separator/>
                                        <MenuItem Header="Help…"
                                                  Click="HelpMenuItem_Click"/>
                                        <MenuItem Header="About…"
                                                  Click="AboutMenuItem_Click"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </Grid>
                    </Viewbox>
                </DataTemplate>
            </dragablz:TabablzControl.ContentTemplate>
        </dragablz:TabablzControl>

    </DockPanel>
</ui:FluentWindow>
