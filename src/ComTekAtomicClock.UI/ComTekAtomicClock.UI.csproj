<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\ComTekAtomicClock.Shared\ComTekAtomicClock.Shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!--
      Dragablz removed in v0.0.33. The library was the source of nearly
      every tab-related bug we fought across v0.0.14..v0.0.32 (header
      refresh PropertyChanged unreliability, click/drag classifier
      swallowing single clicks, NotImplementedException on
      CollectionChanged.Replace, headers in a separate visual subtree).
      Replaced with native System.Windows.Controls.TabControl + a
      ControlTemplate-replaced TabItem ItemContainerStyle. Tear-away
      gesture removed entirely; explicit "Open in new window" and
      "+ New window" commands replace it.
    -->
    <PackageReference Include="SharpVectors.Reloaded" Version="1.8.5" />
    <PackageReference Include="System.ServiceProcess.ServiceController" Version="8.0.0" />
    <PackageReference Include="WPF-UI" Version="4.2.1" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Version>1.1.0</Version>
    <AssemblyVersion>1.1.0.0</AssemblyVersion>
    <FileVersion>1.1.0.0</FileVersion>
    <!--
      App icon embedded into the .exe (taskbar, Alt+Tab, file
      explorer, minimized window-square). Generated by
      tools/build-icon.ps1; regenerate after design changes.
    -->
    <ApplicationIcon>Assets\AppIcon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <!-- Also include as content so Window.Icon can load it at runtime. -->
    <Resource Include="Assets\AppIcon.ico" />
    <!--
      v1.1.0 — Captain John's Marina (CaptJohn theme) assets.
      The original logo JPG is consumed by ClockFaceControl's BuildCaptJohn
      via pack://application:,,,/Assets/JohnsMarina-logo.jpg and rendered
      at 40% opacity inside the inner face circle.
    -->
    <Resource Include="Assets\JohnsMarina-logo.jpg" />
    <!--
      v1.1.0 — Cinzel variable font (OFL) for the bordeaux "12" / "5"
      numerals that flash on CaptJohn during the noon and 5pm windows.
      Linked from windows/design/fonts/ to keep the design folder as the
      single source of truth — touching the .ttf there updates the embed.
      Reference at runtime via pack URI:
         pack://application:,,,/Assets/Fonts/Cinzel-Variable.ttf#Cinzel
    -->
    <Resource Include="..\..\design\fonts\Cinzel-Variable.ttf" Link="Assets\Fonts\Cinzel-Variable.ttf" />
  </ItemGroup>

  <!--
    Theme preview SVGs. These live in design/themes/ (the canonical
    design source) and are linked into the UI assembly as resources so
    the Themes gallery dialog can render them at runtime via SharpVectors
    SvgViewbox at pack://application:,,,/Assets/themes/<name>.svg.
    Linking (rather than copying) keeps the design folder as the single
    source of truth — touching the SVG there updates the gallery.
  -->
  <ItemGroup>
    <Resource Include="..\..\design\themes\atomic-lab.svg"     Link="Assets\themes\atomic-lab.svg" />
    <Resource Include="..\..\design\themes\boulder-slate.svg"  Link="Assets\themes\boulder-slate.svg" />
    <Resource Include="..\..\design\themes\aero-glass.svg"     Link="Assets\themes\aero-glass.svg" />
    <Resource Include="..\..\design\themes\cathode.svg"        Link="Assets\themes\cathode.svg" />
    <Resource Include="..\..\design\themes\concourse.svg"      Link="Assets\themes\concourse.svg" />
    <Resource Include="..\..\design\themes\daylight.svg"       Link="Assets\themes\daylight.svg" />
    <Resource Include="..\..\design\themes\flip-clock.svg"     Link="Assets\themes\flip-clock.svg" />
    <Resource Include="..\..\design\themes\marquee.svg"        Link="Assets\themes\marquee.svg" />
    <Resource Include="..\..\design\themes\slab.svg"           Link="Assets\themes\slab.svg" />
    <Resource Include="..\..\design\themes\binary.svg"         Link="Assets\themes\binary.svg" />
    <Resource Include="..\..\design\themes\hex.svg"            Link="Assets\themes\hex.svg" />
    <Resource Include="..\..\design\themes\binary-digital.svg" Link="Assets\themes\binary-digital.svg" />
    <!--
      v1.1.0 — CaptJohn theme uses a rendered mockup PNG for its gallery
      preview (no hand-illustrated SVG yet). Pack URI:
        pack://application:,,,/Assets/themes/captjohn-mockup.png
    -->
    <Resource Include="..\..\design\themes\captjohn-mockup.png" Link="Assets\themes\captjohn-mockup.png" />
  </ItemGroup>

</Project>
