<ui:FluentWindow x:Class="ComTekAtomicClock.UI.FloatingClockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:ComTekAtomicClock.UI.Controls"
        Title="ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="500" Width="500"
        MinHeight="320" MinWidth="320"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="Manual">

    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </ui:FluentWindow.Resources>

    <!--
      v0.0.33 simplification: a FloatingClockWindow is now a single-
      clock window. Previously it hosted a Dragablz TabablzControl so
      torn-off tabs could land in it (and be re-torn elsewhere). With
      tear-away removed, the window's role is purely "this clock lives
      on my desktop, not in the main window's tab strip."

      DataContext is set to the single TabViewModel for this clock by
      the caller (MainWindowViewModel.OpenInNewWindow / NewClockWindow).

      To migrate this clock back into the main window's tab strip, use
      the "?" overlay menu → "Bring back into tabs" item.
    -->

    <DockPanel>
        <!--
          Title bar so the window can be dragged and closed.
        -->
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="{Binding Label}"
                     ShowMaximize="True"
                     ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!--
          Same Viewbox-scaled 400×400 logical canvas as MainWindow's
          tab content. Identical clock-face + overlay-button stack.
          Differences from MainWindow:
            · ✕ button closes the WINDOW, not "this tab in the strip."
            · "?" menu adds a "Bring back into tabs" item (instead of
              the per-tab close path; this window already has an OS
              close button).
        -->
        <Viewbox Stretch="Uniform" Margin="20">
            <Grid Width="400" Height="400">
                <controls:ClockFaceControl x:Name="ClockFace"
                    Width="400" Height="400"
                    TimeZone="{Binding TimeZone}"
                    Theme="{Binding Theme}"
                    SmoothSecondHand="{Binding SmoothSecondHand}"
                    CaptJohnHoraChapinEnabled="{Binding CaptJohnHoraChapin}"
                    CaptJohnDemoMode="{Binding CaptJohnDemoMode}"/>

                <!--
                  v0.0.35: single overlay button hosting ALL options.
                  Replaces the v0.0.34 stacked ✕ + ? overlay pair. Per
                  Dan: "the 'x' on the clock face is redundant on the
                  new clock face (they can just hit the one in the
                  corner), change it to something else." OS title-bar
                  X already closes the window; ✕ overlay deleted.

                  Glyph: ui:SymbolIcon Symbol="MoreHorizontal20" — the
                  Fluent three-dot "more options" affordance, identical
                  to the one Windows 11 itself uses across the shell.
                  Foreground bound to TabViewModel.OverlayGlyphBrush so
                  it picks up white on dark themes / near-black on
                  light themes.
                -->
                <Button HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,14,16,0"
                        Width="26" Height="22"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="More options"
                        Click="MoreOptionsButton_Click">
                    <ui:SymbolIcon Symbol="MoreHorizontal20"
                                   FontSize="16"
                                   Foreground="{Binding OverlayGlyphBrush}"/>
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Settings…"
                                      Click="SettingsMenuItem_Click"/>
                            <MenuItem Header="Themes…"
                                      Click="ThemesMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="Bring back into tabs"
                                      Click="BringIntoTabsMenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="Help…"
                                      Click="HelpMenuItem_Click"/>
                            <MenuItem Header="About…"
                                      Click="AboutMenuItem_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>

                <!--
                  v1.1.1 — Jolly Roger ☠ overlay button. Same shape as
                  the MainWindow tab-content version: lower-left, only
                  visible on CaptJohn theme, ContextMenu hosting Hora
                  Chapín (checkable, persistent) + Almuerzo / Fini
                  (momentary demos), Closed handler clears demo state.
                -->
                <Button HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="14,0,0,14"
                        Width="44" Height="44"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Captain John's options"
                        Visibility="{Binding IsCaptJohnTheme, Converter={StaticResource BoolToVis}}"
                        Click="JollyRogerButton_Click">
                    <TextBlock Text="&#x2620;"
                               FontSize="36"
                               Foreground="{Binding OverlayGlyphBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    <Button.ContextMenu>
                        <!--
                          v1.1.3: no Closed handler — demos persist
                          across menu close until the user explicitly
                          toggles the radio off (or picks the other
                          demo, which auto-clears via the radio-style
                          IsAlmuerzoActive / IsFiniActive setters).
                        -->
                        <ContextMenu>
                            <MenuItem Header="Hora Chapín"
                                      IsCheckable="True"
                                      IsChecked="{Binding CaptJohnHoraChapin, Mode=TwoWay}"
                                      StaysOpenOnClick="True"/>
                            <Separator/>
                            <MenuItem Header="Almuerzo (12:00 demo)"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsAlmuerzoActive, Mode=TwoWay}"
                                      StaysOpenOnClick="True"/>
                            <MenuItem Header="Fini (5:00 PM demo)"
                                      IsCheckable="True"
                                      IsChecked="{Binding IsFiniActive, Mode=TwoWay}"
                                      StaysOpenOnClick="True"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
        </Viewbox>
    </DockPanel>
</ui:FluentWindow>
