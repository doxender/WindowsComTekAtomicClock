<ui:FluentWindow x:Class="ComTekAtomicClock.UI.Dialogs.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="About ComTek Atomic Clock"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="520" Height="430"
        Foreground="#f0e8c8"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="About ComTek Atomic Clock"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="ComTek Atomic Clock"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#FFB000"
                           VerticalAlignment="Center"/>
                <Border Background="#7a3a1a"
                        BorderBrush="#FFB000"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,2"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="ALPHA"
                               FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#fff5d8"/>
                </Border>
            </StackPanel>
            <TextBlock x:Name="VersionText"
                       Text="Version 0.1.0-dev"
                       FontFamily="Consolas, Courier New"
                       FontSize="11"
                       Foreground="#A8A39A"
                       Margin="0,2,0,0"/>
            <TextBlock Text="Pre-release — not yet tested for public use. Behavior and settings format may change between commits."
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="11"
                       Foreground="#FFB000"
                       Opacity="0.85"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="A Windows desktop clock that syncs to NIST stratum-1 atomic time servers in Boulder, CO and Gaithersburg, MD."
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="13"
                       TextWrapping="Wrap"
                       LineHeight="20"
                       Foreground="#D8D2BC"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Background="#040b04"
                      Padding="14,10"
                      BorderBrush="#FFB000"
                      BorderThickness="0.6">
            <StackPanel>
                <TextBlock Text="Copyright"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FFB000"/>
                <TextBlock Text="© 2026 Daniel V. Oxender. All rights reserved."
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12"
                           Foreground="#D8D2BC"
                           Margin="0,2,0,12"/>

                <TextBlock Text="License — MIT"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FFB000"/>
                <TextBlock TextWrapping="Wrap"
                           FontFamily="Consolas, Courier New"
                           FontSize="11"
                           Foreground="#D8D2BC"
                           LineHeight="16"
                           Margin="0,4,0,12"
                           Text="Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#x0A;&#x0A;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#x0A;&#x0A;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE."/>

                <TextBlock Text="Time source"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FFB000"/>
                <TextBlock Text="National Institute of Standards and Technology (NIST). Stratum-1 NTP pool published at https://tf.nist.gov/tf-cgi/servers.cgi. NIST is a U.S. federal agency; their time service is free for public use within the published rate-limit (≥ 4 s/server)."
                           TextWrapping="Wrap"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12"
                           Foreground="#D8D2BC"
                           LineHeight="16"
                           Margin="0,4,0,12"/>

                <TextBlock Text="Source"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#FFB000"/>
                <TextBlock Text="https://github.com/doxender/WindowsComTekAtomicClock"
                           FontFamily="Consolas, Courier New"
                           FontSize="11"
                           Foreground="#A0E0FF"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="3" Margin="0,16,0,0">
            <Button x:Name="OkButton"
                    DockPanel.Dock="Right"
                    Content="OK"
                    Width="90" Height="28"
                    Click="OkButton_Click"
                    IsDefault="True" IsCancel="True"/>
            <Button x:Name="UninstallServiceButton"
                    HorizontalAlignment="Left"
                    Content="Uninstall the time-sync service…"
                    Padding="10,4"
                    Background="Transparent"
                    Foreground="#A0E0FF"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="UninstallServiceButton_Click"/>
        </DockPanel>
    </Grid>
    </DockPanel>
</ui:FluentWindow>
