<ui:FluentWindow x:Class="ComTekAtomicClock.UI.Dialogs.TabSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:services="clr-namespace:ComTekAtomicClock.UI.Services"
        xmlns:settings="clr-namespace:ComTekAtomicClock.Shared.Settings;assembly=ComTekAtomicClock.Shared"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Settings"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="560" Height="540"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <ui:FluentWindow.Resources>
        <ObjectDataProvider x:Key="ThemeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="settings:Theme"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </ui:FluentWindow.Resources>

    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="Settings"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <!-- Header + editing-tab subline -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Section: This tab -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Section: All clocks on this PC -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>

                <!-- Spacer + buttons -->
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="#FFB000"
                       Margin="0,0,0,4">
                <Run x:Name="TabHeaderText" Text="Settings"/>
            </TextBlock>
            <TextBlock x:Name="EditingTabLabel" Grid.Row="1"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="11"
                       Foreground="#A8A39A"
                       Margin="0,0,0,18"/>

            <!-- ===================== Section: This tab ===================== -->
            <TextBlock Grid.Row="2"
                       Text="THIS TAB"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#FFB000"
                       Opacity="0.85"
                       Margin="0,0,0,8"/>

            <!-- Time zone -->
            <TextBlock Grid.Row="3"
                       Text="Time zone"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="11"
                       Foreground="#A8A39A"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="TimezoneCombo" Grid.Row="4"
                      ItemsSource="{Binding Source={x:Static services:TimeZoneCatalog.All}}"
                      SelectedValuePath="IanaId"
                      DisplayMemberPath="DisplayName"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      TextSearch.TextPath="DisplayName"
                      MaxDropDownHeight="240"
                      Margin="0,0,0,12"/>

            <!-- Theme -->
            <TextBlock Grid.Row="5"
                       Text="Theme"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="11"
                       Foreground="#A8A39A"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="ThemeCombo" Grid.Row="6"
                      ItemsSource="{Binding Source={StaticResource ThemeValues}}"
                      Margin="0,0,0,18"/>

            <!-- =============== Section: All clocks on this PC =============== -->
            <!--
              Machine-wide setting. Lives in the same dialog because we
              don't want a second "Preferences" entry point cluttering
              the ? overlay menu, but the section heading + subtext make
              the broader scope explicit so users don't think they're
              just tweaking this one tab. Persisted in service.json under
              %ProgramData%, which the Service re-reads each sync loop.
            -->
            <TextBlock Grid.Row="7"
                       Text="ALL CLOCKS ON THIS PC"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="#FFB000"
                       Opacity="0.85"
                       Margin="0,4,0,4"/>
            <TextBlock Grid.Row="8"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="10"
                       Foreground="#888"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8"
                       Text="Applies to every tab and to the system clock itself — controls how often the time-sync service queries NIST atomic time."/>

            <TextBlock Grid.Row="9"
                       Text="Sync frequency"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="11"
                       Foreground="#A8A39A"
                       Margin="0,0,0,4"/>
            <ComboBox x:Name="SyncIntervalCombo" Grid.Row="10"
                      Margin="0,0,0,12">
                <!--
                  Tag carries the interval as integer hours; the visible
                  text is the friendly label. Code-behind round-trips
                  these to TimeSpan when reading/writing service.json.
                -->
                <ComboBoxItem Content="Every 6 hours"  Tag="6"/>
                <ComboBoxItem Content="Every 12 hours" Tag="12"/>
                <ComboBoxItem Content="Every 24 hours" Tag="24"/>
            </ComboBox>

            <!-- Buttons -->
            <StackPanel Grid.Row="12"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Cancel"
                        Width="100" Height="30"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="CancelButton_Click"/>
                <Button Content="Save"
                        Width="100" Height="30"
                        IsDefault="True"
                        Background="#FFB000"
                        Foreground="#0a0a0a"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
