<ui:FluentWindow x:Class="ComTekAtomicClock.UI.Dialogs.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="ComTek Atomic Clock — Help"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Width="560" Height="540"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel>
        <ui:TitleBar DockPanel.Dock="Top"
                     Title="ComTek Atomic Clock — Help"
                     ShowMaximize="False"
                     ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Assets/AppIcon.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="How to use the clock"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="#FFB000"
                       Margin="0,0,0,16"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0">
                <StackPanel>

                    <TextBlock Text="Tabs and time zones"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="#FFB000" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="20"
                               Foreground="#D8D2BC" FontSize="12"
                               Margin="0,0,0,16"
                               Text="Each tab is a clock bound to one IANA time zone. Add as many as you want — one per city you care about — and switch between them by clicking the tab header."/>

                    <TextBlock Text="• Add a tab" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock Text="Click the + button at the right end of the tab strip. New tabs default to UTC and Atomic Lab; edit them as below."
                               TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Text="• Edit a tab (timezone, theme)" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,10"
                               Text="Double-click the tab header, OR right-click the tab and choose &quot;Tab settings…&quot;, OR press Ctrl+, while the tab is active. The Settings dialog has two sections: &quot;THIS TAB&quot; (time zone, theme) and &quot;ALL CLOCKS ON THIS PC&quot; (sync frequency — applies to every tab and to the system clock itself). Save / Cancel."/>

                    <TextBlock Text="• Pick a different theme" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,10"
                               Text="Click the &quot;?&quot; overlay button on the clock face → &quot;Themes…&quot; for a 12-tile gallery (six analog, six digital). Click a tile to apply that theme to the tab and persist."/>

                    <TextBlock Text="• Reorder tabs" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock Text="Drag a tab horizontally within the strip to change its position."
                               TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,10"/>

                    <TextBlock Text="• Tear off into its own window" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,10"
                               Text="Tearing a tab off works the same way as in Google Chrome: grab the tab header and drag it down/away from the tab strip — when you cross the strip's edge it pops into its own floating window that you can move and resize independently. Drag it back over the main strip to reattach. Closing a floating window with a tab still inside reattaches the tab automatically."/>

                    <TextBlock Text="• Close a tab" FontWeight="SemiBold" Foreground="#FFB000" FontSize="12"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18" Foreground="#D8D2BC" FontSize="12" Margin="0,0,0,16"
                               Text="Click the small ✕ on the tab header, OR the ✕ button in the upper-right corner of the clock face, OR right-click the tab and choose &quot;Close tab&quot;. Closing the LAST tab in the main window exits the app."/>

                    <TextBlock Text="The time-sync service"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="#FFB000" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18"
                               Foreground="#D8D2BC" FontSize="12"
                               Margin="0,0,0,10"
                               Text="A separate Windows Service queries NIST's stratum-1 time servers in Boulder, CO and adjusts your system clock. It only runs while the clock app is open — it auto-starts when you launch the app and stops when you close it. Default sync cadence is every 12 hours; change it in any tab's Settings dialog under &quot;ALL CLOCKS ON THIS PC&quot; (6 / 12 / 24 hours)."/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18"
                               Foreground="#D8D2BC" FontSize="12"
                               Margin="0,0,0,16"
                               Text="If the service is not installed, an orange banner at the top of the window will offer to install it (one-time UAC prompt). To remove it cleanly, open About → &quot;Uninstall the time-sync service…&quot;."/>

                    <TextBlock Text="Status bar"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="#FFB000" Margin="0,0,0,4"/>
                    <TextBlock TextWrapping="Wrap" LineHeight="18"
                               Foreground="#D8D2BC" FontSize="12"
                               Margin="0,0,0,10"
                               Text="The bottom of the window shows the current service state (Running / Installed but stopped / Not installed) and the live last-sync readout — &quot;Last sync: 12s ago (corrected −8.7 ms)&quot;, refreshed every second. − means the system clock was running fast and was pulled back; + means it was slow and was pushed forward."/>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="OK"
                        Width="90" Height="28"
                        Click="OkButton_Click"
                        IsDefault="True" IsCancel="True"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</ui:FluentWindow>
