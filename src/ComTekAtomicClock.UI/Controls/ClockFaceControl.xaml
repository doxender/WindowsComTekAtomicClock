<UserControl
    x:Class="ComTekAtomicClock.UI.Controls.ClockFaceControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    MinWidth="200" MinHeight="200"
    Background="Transparent"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <!--
      Theme-pluggable clock face. The Canvas is intentionally empty
      in XAML; everything is rendered in code-behind by the per-theme
      Build<ThemeName>() routines. This keeps each theme's visual
      definition next to the others (one file, easy to compare and
      tweak) and lets us add new themes with minimal ceremony — see
      ClockFaceControl.xaml.cs.

      Internal coordinate system is a fixed 400x400 with the dial
      center at (200, 200), exactly matching the SVG mockups in
      design/themes/. The Viewbox + Stretch=Uniform makes the whole
      composition scale to fill the parent while preserving 1:1
      aspect ratio.
    -->
    <Viewbox Stretch="Uniform">
        <Canvas x:Name="Dial" Width="400" Height="400" ClipToBounds="False"/>
    </Viewbox>
</UserControl>
